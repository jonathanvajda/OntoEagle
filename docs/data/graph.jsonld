  {
    "@id": "https://www.commoncoreontologies.org/ont00001648",
    "@type": [
      "https://www.commoncoreontologies.org/ont00001351",
      "https://www.commoncoreontologies.org/ont00000469",
      "http://www.w3.org/2002/07/owl#NamedIndividual"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Earth-Centered Earth-Fixed Coordinate System"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@language": "en",
        "@value": "ECR"
      },
      {
        "@language": "en",
        "@value": "Earth Centered Earth Fixed"
      },
      {
        "@language": "en",
        "@value": "Earth-Centered Earth-Fixed"
      },
      {
        "@language": "en",
        "@value": "ECEF"
      },
      {
        "@language": "en",
        "@value": "Earth Centered Rotational Coordinate System"
      },
      {
        "@language": "en",
        "@value": "Earth-Centered, Earth-Fixed"
      },
      {
        "@language": "en",
        "@value": "Conventional Terrestrial Coordinate System"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Geospatial and Cartesian Coordinate System that identifies positions using an x-axis, y-axis, and z-axis coordinate where the zero point is the center of the Earth, the z-Axis extends toward the North Pole but does not always coincide exactly with the Earth's Axis of Rotation, the x-Axis extends through the intersection of the Prime Meridian and the Equator, the y-Axis completes the right-handed system, and all three axes are fixed to the Earth such that they rotate along with the Earth."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001754": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://en.wikipedia.org/w/index.php?title=Earth-centered,_Earth-fixed_coordinate_system&oldid=1062678600"
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://www.commoncoreontologies.org/InformationEntityOntology"
      }
    ]
  },
  {
    "@id": "https://www.commoncoreontologies.org/ont00001550",
    "@type": [
      "https://www.commoncoreontologies.org/ont00000276",
      "http://www.w3.org/2002/07/owl#NamedIndividual"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "The Julian Calendar was proposed by Julius Caesar as a reform of the Roman Calendar, took effect on 1 January 46 BC, and was the predominant Calendar System in Europe until being largely replaced by the Gregorian Calendar."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Julian Calendar"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Solar Calendar System that has a regular Year of 365 24-Hour Days divided into 12 Months with a leap day added at the end of February every 4 Years such that the average length of a Julian Year is 365.25 Days."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001754": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://en.wikipedia.org/w/index.php?title=Julian_calendar&oldid=1063127575"
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://www.commoncoreontologies.org/InformationEntityOntology"
      }
    ]
  },
  {
