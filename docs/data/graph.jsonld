      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "An Act of Training Acquisition performed by an Agent by acquiring knowledge of the tactics, techniques, and/or strategies of the use of violence against civilians in order to attain goals that are political, religous, or ideological in nature from an Agent or communication medium that realizes a capacity derived from its affiliation with a Terrorist Organization."
      }
    ],
