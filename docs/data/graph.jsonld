  {
    "@id": "https://www.commoncoreontologies.org/ont00000312",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Propulsion Process"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00000007"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Natural Process in which one or more Forces are generated and applied to a participating Object such that the Object is set in Motion or has the direction or magnitude of its Motion altered."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "burning a portion of fuel to produce exhaust that is ejected through a jet nozzle to propel a rocket and its payload"
      },
      {
        "@value": "an apple falling to the ground under the power of Earth's gravitational force"
      },
      {
        "@value": "the wind blowing leaves across a lawn"
      },
      {
        "@value": "turning a paddle wheel against a portion of water to propel the paddle boat forward"
      },
      {
        "@value": "launching a water balloon using a sling shot"
      },
      {
        "@value": "heat from a fire causing ashes to rise into the sky"
      },
      {
        "@value": "a twin-engine turboprop plane rotating both of its propellers against a portion of atmosphere to propel the plane forward"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "In each case, a Propulsion Process minimally involves the Object being propelled, a Reaction Mass (e.g. a portion of water, atmosphere, exhaust, etc.), and the Force(s) acting between these two entities."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://www.commoncoreontologies.org/EventOntology"
      }
    ]
  },
  {
    "@id": "http://www.w3.org/2004/02/skos/core#broaderTransitive",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty",
      "http://www.w3.org/2002/07/owl#TransitiveProperty",
      "http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://www.w3.org/2004/02/skos/core"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "has broader transitive"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "http://www.w3.org/2004/02/skos/core#semanticRelation"
      }
    ],
    "http://www.w3.org/2002/07/owl#inverseOf": [
      {
        "@id": "http://www.w3.org/2004/02/skos/core#narrowerTransitive"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "skos:broaderTransitive is a transitive superproperty of skos:broader."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "By convention, skos:broaderTransitive is not used to make assertions. Rather, the properties can be used to draw inferences about the transitive closure of the hierarchical relation, which is useful e.g. when implementing a simple query expansion algorithm in a search application."
      }
    ]
  },
