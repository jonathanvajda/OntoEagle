      }
    ]
  },
  {
    "@id": "http://www.w3.org/ns/dcat#startDate",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty",
      "http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "http://purl.org/dc/terms/PeriodOfTime"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://www.w3.org/TR/vocab-dcat-2/"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "data di inizio"
      },
      {
        "@language": "cs",
        "@value": "datum začátku"
      },
      {
        "@language": "en",
        "@value": "start date"
      },
      {
        "@language": "da",
        "@value": "startdato"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2000/01/rdf-schema#Literal"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@language": "da",
        "@value": "starttidspunkt"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#changeNote": [
      {
        "@language": "da",
        "@value": "Ny egenskab tilføjet i DCAT 2."
      },
      {
        "@language": "en",
        "@value": "New property added in DCAT 2."
      },
      {
        "@language": "cs",
        "@value": "Nová vlastnost přidaná ve verzi DCAT 2."
      },
      {
        "@language": "it",
        "@value": "Nuova proprietà aggiunta in DCAT 2."
      },
      {
        "@language": "es",
        "@value": "Nueva propiedad agregada en DCAT 2."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "it",
        "@value": "L'inizio del periodo"
      },
      {
        "@language": "es",
        "@value": "El comienzo del período"
      },
      {
        "@language": "da",
        "@value": "Start på perioden."
      },
      {
        "@language": "en",
        "@value": "The start of the period"
      },
      {
        "@language": "cs",
        "@value": "Začátek doby trvání"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "The range of this property is intentionally generic, with the purpose of allowing different level of temporal precision for specifying the start of a period. E.g., it can be expressed with a date (xsd:date), a date and time (xsd:dateTime), or a year (xsd:gYear)."
      },
      {
        "@language": "it",
        "@value": "Il range di questa proprietà è volutamente generico, con lo scopo di consentire diversi livelli di precisione temporale per specificare l'inizio di un periodo. Ad esempio, può essere espresso con una data (xsd:date), una data e un'ora (xsd:dateTime), o un anno (xsd:gYear)."
      },
      {
        "@language": "cs",
        "@value": "Obor hodnot této vlastnosti je úmyslně obecný, aby umožnil různé úrovně časového rozlišení pro specifikaci začátku doby trvání. Ten může být kupříkladu vyjádřen datumem (xsd:date), datumem a časem (xsd:dateTime) či rokem (xsd:gYear)."
      },
      {
        "@language": "da",
        "@value": "Rækkeviden for denne egenskab er bevidst generisk defineret med det formål at tillade forskellige niveauer af tidslig præcision ifm. angivelse af startdatoen for en periode. Den kan eksempelvis udtrykkes som en dato (xsd:date), en dato og et tidspunkt (xsd:dateTime), eller et årstal (xsd:gYear)."
      },
      {
        "@language": "es",
        "@value": "El rango de esta propiedad es intencionalmente genérico con el propósito de permitir distintos niveles de precisión temporal para especificar el comienzo de un período. Por ejemplo, puede expresarse como una fecha (xsd:date), una fecha y un tiempo (xsd:dateTime), o un año (xsd:gYear)."
      }
    ]
  },
