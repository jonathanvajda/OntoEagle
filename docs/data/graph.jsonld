  {
    "@id": "http://www.w3.org/ns/dcat#prev",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty",
      "http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "La risorsa precedente a quella attuale in una collezione ordinata o in una serie di risorse."
      },
      {
        "@language": "en",
        "@value": "The previous resource (before the current one) in an ordered collection or series of resources."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://www.w3.org/TR/vocab-dcat-3/"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "es",
        "@value": "previo"
      },
      {
        "@language": "it",
        "@value": "precedente"
      },
      {
        "@language": "en",
        "@value": "previous"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "http://www.w3.org/1999/xhtml/vocab#prev"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#changeNote": [
      {
        "@language": "it",
        "@value": "Nuova proprietà aggiunta in DCAT 3."
      },
      {
        "@language": "es",
        "@value": "Nueva propiedad agregada in DCAT 3."
      },
      {
        "@language": "cs",
        "@value": "Nová vlastnost přidaná ve verzi DCAT 3."
      },
      {
        "@language": "da",
        "@value": "Ny egenskab tilføjet i DCAT 3."
      },
      {
        "@language": "en",
        "@value": "New property added in DCAT 3."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "The previous resource (before the current one) in an ordered collection or series of resources."
      },
      {
        "@language": "it",
        "@value": "La risorsa precedente a quella attuale in una collezione ordinata o in una serie di risorse."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "It is important to note that this property is different from dcat:previousVersion, as it does not denote a previous version of the same resource, but a distinct resource immediately preceding the current one in an ordered collection of resources."
      },
      {
        "@language": "it",
        "@value": "È importante notare che questa proprietà è diversa da dcat:previousVersion, dato che non indica una versione precedente della stessa risorsa, ma una risorsa distinta che precede immediatamente quella attuale in una collezione ordinata di risorse."
      },
      {
        "@language": "en",
        "@value": "In DCAT this property is used for resources belonging to a dcat:DatasetSeries."
      },
      {
        "@language": "it",
        "@value": "In DCAT questa proprietà è usata per risorse che fanno parte di una dcat:DatasetSeries."
      },
      {
        "@language": "es",
        "@value": "En DCAT esta propiedad se usa para recursos que pertenecen a una dcat:DatasetSeries."
      }
    ]
  },
