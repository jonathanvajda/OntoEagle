      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Planned Act that involves determining the extent, dimensions, quanity, or quality of an Entity relative to some standard."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "using a tape measure to determine the height and width of a doorway in inches"
      },
      {
        "@value": "rating Hollywood movies on a 1 to 5 star scale"
      },
      {
        "@value": "putting an object on a scale to measure its weight in kilograms"
      }
    ],
