  {
    "@id": "https://www.commoncoreontologies.org/ont00001909",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "http://purl.obolibrary.org/obo/BFO_0000141"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "has tangential part"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://purl.obolibrary.org/obo/BFO_0000141"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00001855"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "x has_tangential_part y iff x, y, and z are instances of Immaterial Entity, and x has_spatial_part y, such that z externally connects with both x and y."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "Given a stronger temporal interpretation, this property may be transitive. For more info please refer to https://github.com/BFO-ontology/BFO-2020/tree/master/src/owl/temporal%20extensions."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001754": [
      {
        "@language": "en",
        "@value": "Randell, D. A., Cui, Z. and Cohn, A. G.: 1992, \"A spatial logic based on regions and connection,\" Proc. 3rd Int. Conf. on Knowledge Representation and Reasoning, Morgan Kaufmann, San Mateo, pp. 165-176. Available at: https://www.dpi.inpe.br/gilberto/references/cohn_rcc.pdf"
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://www.commoncoreontologies.org/GeospatialOntology"
      }
    ]
  },
  {
    "@id": "http://www.ontologyrepository.com/CommonCoreOntologies/MemoryCorruption",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Memory Corruption"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://www.ontologyrepository.com/CommonCoreOntologies/CyberVulnerability"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Cyber Vulnerability that is realized by a Cyber Attack which writes to memory outside the bounds of a buffer, when the root cause is something other than a sequential copies of excessive data from a fixed starting location."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "This may include issues such as incorrect pointer arithmetic, accessing invalid pointers due to incomplete initialization or memory release, etc."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"
      }
    ]
  },
  {
    "@id": "http://purl.obolibrary.org/obo/BFO_0000011",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://purl.org/dc/elements/1.1/identifier": [
      {
        "@value": "095-BFO"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "spatiotemporal region"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://purl.obolibrary.org/obo/BFO_0000003"
      },
      {
        "@id": "_:n7a8f9273c02645229d07824ea86e8825b102"
      },
      {
        "@id": "_:n7a8f9273c02645229d07824ea86e8825b101"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "(Elucidation) A spatiotemporal region is an occurrent that is an occurrent part of spacetime"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@language": "en",
        "@value": "The spatiotemporal region occupied by the development of a cancer tumour; the spatiotemporal region occupied by an orbiting satellite"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "'Spacetime' here refers to the maximal instance of the universal spatiotemporal region."
      }
    ]
  },
