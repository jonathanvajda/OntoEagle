  {
    "@id": "https://github.com/jonathanvajda/cco-d-acts/ont00000024",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://purl.obolibrary.org/obo/IAO_0000114": [
      {
        "@id": "http://purl.obolibrary.org/obo/IAO_0000123"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "this is not importantly different from causal responsibility's definition (draft)"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00001017"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "is normatively accountable for"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://purl.obolibrary.org/obo/BFO_0000015"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "x is normatively accountable for y iff x is an Agent, y is a Process, and z is a Process, and x is agent_in z, and z is the cause of y"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@language": "en",
        "@value": "parent is a responsible for a child"
      },
      {
        "@language": "en",
        "@value": "manager is responsible for the subordinate's actions"
      },
      {
        "@language": "en",
        "@value": "parent is responsible or a child's actions"
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://github.com/jonathanvajda/cco-d-acts"
      }
    ]
  },
