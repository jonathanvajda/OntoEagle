        "@value": "Ramjet"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "An Air-Breathing Jet Engine that uses the forward motion of the Engine to compress incoming air (without the use of an axial compressor) and decelerate it to subsonic speeds before adding the fuel and constantly combusting the mixture then expelling the exhaust out through the rear Propelling Nozzle to generate Thrust."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001754": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
