      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://www.commoncoreontologies.org/ArtifactOntology"
      }
    ]
  },
  {
    "@id": "http://www.ontologyrepository.com/CommonCoreOntologies/CybersecurityIncident",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://purl.org/dc/terms/creator": [
      {
        "@language": "en",
        "@value": "CUBRC Inc"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "TO DO: Add a term(s) for Confidentiality, Integrity, and Accessibility (CIA) of data. Then use these terms to refine the definition of Cybersecurity Incident.\n\nThis is needed because scoping the range of consequences that make a Cyber Act qualify as a Cybersecurity Incident is challenging. For example, consider a scenario where a major credit reporting agency experiences a data breach/spill that affects millions of people but at least some of those people are not owners/users/etc. of that database. Damage is done and this should be typed as a Cybersecurity Incident, but how do we capture these \"outside\" agents without making the definition too broad? For example, we probably don't want to include cyber bullying that causes real world harm as Cybersecurity Incidents."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Cybersecurity Incident"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://www.ontologyrepository.com/CommonCoreOntologies/CybersecurityAct"
      }
    ],
    "http://www.w3.org/2002/07/owl#equivalentClass": [
      {
        "@id": "_:nf80cdc07e044424c93853a9c46ec024eb59"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@language": "en",
        "@value": "Cyber Attack Consequence"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Cybersecurity Act that causes an adverse effect to a Computer Network, the information residing therein, or its authorized users or owners."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@language": "en",
        "@value": "the outcome of a successful cyber attack"
      },
      {
        "@language": "en",
        "@value": "a data breach or data spill"
      }
    ],
    "https://www.commoncoreontologies.org/ont00001754": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://www.bitlyft.com/resources/security-incident-vs-event-what-is-the-difference"
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://csrc.nist.gov/glossary/term/cyber_incident"
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"
      }
    ]
  },
