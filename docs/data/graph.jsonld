      {
        "@language": "en",
        "@value": "describes condition"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00001808"
      }
    ],
    "http://www.w3.org/2002/07/owl#propertyChainAxiom": [
      {
        "@list": [
          {
            "@id": "http://purl.obolibrary.org/obo/BFO_0000178"
          },
          {
            "@id": "https://www.commoncoreontologies.org/ont00001982"
          }
        ]
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "p describes_condition c iff p is an instance of a Performance Specification, and p has part d, and d is an instance of a Descriptive Information Content Entity, and p prescribes an entity s, and d describes c, and c is an entity that is causally relevant to s existing as prescribed by p."
      }
    ],
