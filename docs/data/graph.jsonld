    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A Beginning of Life Stasis (BoL) is a relatively brief Operational Stasis that is primarily of interest for the purpose of establishing a baseline for operational parameters to be compared to the designed specifications as well as the Artifact's performance throughout its operational life."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Beginning of Life Stasis"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00001191"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Operational Stasis that holds during a Temporal Interval when an Artifact is first put into operational use such that its designed set of Artifact Functions is capable of operating at or near their designed peak performance levels."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001753": [
      {
        "@value": "BOL"
      },
      {
        "@value": "BoL"
      }
    ],
