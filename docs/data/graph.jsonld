      {
        "@language": "da",
        "@value": "har datasæt"
      },
      {
        "@language": "da",
        "@value": "datasamling"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "it",
        "@value": "Una raccolta di dati che è elencata nel catalogo."
      },
      {
        "@language": "en",
        "@value": "A dataset that is listed in the catalog."
      },
      {
        "@language": "el",
        "@value": "Συνδέει έναν κατάλογο με ένα σύνολο δεδομένων το οποίο ανήκει στον εν λόγω κατάλογο."
      },
      {
        "@language": "ar",
        "@value": "تربط الفهرس بقائمة بيانات ضمنه"
      },
      {
        "@language": "fr",
        "@value": "Relie un catalogue à un jeu de données faisant partie de ce catalogue."
      },
      {
        "@language": "cs",
        "@value": "Kolekce dat, která je katalogizována v katalogu."
      },
      {
        "@language": "da",
        "@value": "En samling af data som er opført i kataloget."
      },
      {
        "@language": "ja",
        "@value": "カタログの一部であるデータセット。"
      },
      {
        "@language": "es",
        "@value": "Un conjunto de datos que se lista en el catálogo."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#editorialNote": [
      {
        "@language": "en",
        "@value": "Status: English Definition text modified by DCAT 3 revision team, translations pending."
      }
