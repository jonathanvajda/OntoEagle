      }
    ]
  },
  {
    "@id": "https://www.commoncoreontologies.org/ont00000731",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "'Deviation Measurement Information Content Entity' and 'Veracity Measurement Information Content Entity' are complementary notions. Deviation is a measure of whether reality conforms to an ICE (e.g., a plan or prediction), whereas Veracity is a measure of whether a Descriptive ICE conforms to reality."
      },
      {
        "@language": "en",
        "@value": "Note, the term 'accuracy' is avoided due to its ambiguity between: correctness-of-performance (see: 'Reliability Measurement Information Content Entity'), correctness-of-information (see: 'Veracity Measurement Information Content Entity'), and adherance-to-expectations ('Deviation Measurement Information Content Entity')."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Deviation Measurement Information Content Entity"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00001163"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@language": "en",
        "@value": "Conformance Measurement"
      },
      {
        "@language": "en",
        "@value": "Degree of Conformance"
      },
      {
        "@language": "en",
        "@value": "Degree of Deviation"
      },
      {
        "@language": "en",
        "@value": "Deviation Measurement"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Measurement Information Content Entity that is a measurement of the extent to which an entity conforms to how it is expected or supposed to be."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "a missile impact deviates from its target location by 100 feet"
      },
      {
        "@value": "an overweight piece of luggage deviates from an airline's maximum allowed weight by +10 pounds"
      },
      {
        "@value": "a satellite deviaties from its predicted orbital path by 5 kilometers"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "In order for a Deviation to exist, an entity must first be expected, represented, prescribed, or predicted as being a certain way. Then, at a future time, this value can be compared to its actual, reported, or measured value to determine the Deviation between these values."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://www.commoncoreontologies.org/InformationEntityOntology"
      }
    ]
  },
