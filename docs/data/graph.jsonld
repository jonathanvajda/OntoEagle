  {
    "@id": "http://www.w3.org/ns/dcat#spatialResolutionInMeters",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty",
      "http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en-US",
        "@value": "minimum spatial separation resolvable in a dataset, measured in meters."
      },
      {
        "@language": "cs",
        "@value": "minimální prostorový rozestup rozeznatelný v datové sadě, měřeno v metrech."
      },
      {
        "@language": "da",
        "@value": "mindste geografiske afstand som kan erkendes i et datasæt, målt i meter."
      },
      {
        "@language": "en-GB",
        "@value": "minimum spatial separation resolvable in a dataset, measured in metres."
      },
      {
        "@language": "it",
        "@value": "separazione spaziale minima risolvibile in un set di dati, misurata in metri."
      },
      {
        "@language": "es",
        "@value": "mínima separacíon espacial disponible en un conjunto de datos, medida en metros."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://www.w3.org/TR/vocab-dcat-2/"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "es",
        "@value": "resolución espacial (metros)"
      },
      {
        "@language": "da",
        "@value": "geografisk opløsning (meter)"
      },
      {
        "@language": "en-US",
        "@value": "spatial resolution (meters)"
      },
      {
        "@language": "en-GB",
        "@value": "spatial resolution (metres)"
      },
      {
        "@language": "it",
        "@value": "risoluzione spaziale (metri)"
      },
      {
        "@language": "cs",
        "@value": "prostorové rozlišení (metry)"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#changeNote": [
      {
        "@language": "da",
        "@value": "Ny genskab tilføjet i DCAT 2."
      },
      {
        "@language": "en",
        "@value": "New property added in DCAT 2."
      },
      {
        "@language": "cs",
        "@value": "Nová vlastnost přidaná ve verzi DCAT 2."
      },
      {
        "@language": "it",
        "@value": "Nuova proprietà aggiunta in DCAT 2."
      },
      {
        "@language": "es",
        "@value": "Nueva propiedad añadida en DCAT 2."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en-GB",
        "@value": "minimum spatial separation resolvable in a dataset, measured in metres."
      },
      {
        "@language": "da",
        "@value": "mindste geografiske afstand som kan resolveres i et datasæt, målt i meter."
      },
      {
        "@language": "it",
        "@value": "separazione spaziale minima risolvibile in un set di dati, misurata in metri."
      },
      {
        "@language": "es",
        "@value": "mínima separacíon espacial disponible en un conjunto de datos, medida en metros."
      },
      {
        "@language": "en-US",
        "@value": "minimum spatial separation resolvable in a dataset, measured in meters."
      },
      {
        "@language": "cs",
        "@value": "minimální prostorový rozestup rozeznatelný v datové sadě, měřeno v metrech."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#editorialNote": [
      {
        "@language": "cs",
        "@value": "Může se vyskytnout v popisu Datové sady nebo Distribuce, takže nebyl specifikován definiční obor."
      },
      {
        "@language": "da",
        "@value": "Kan optræde i forbindelse med beskrivelse af datasættet eller datasætditributionen, så der er ikke angivet et domæne for egenskaben."
      },
      {
        "@language": "en",
        "@value": "Might appear in the description of a Dataset or a Distribution, so no domain is specified."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "Alternative spatial resolutions might be provided as different dataset distributions."
      },
      {
        "@language": "it",
        "@value": "Risoluzioni spaziali alternative possono essere fornite come diverse distribuzioni di set di dati."
      },
      {
        "@language": "cs",
        "@value": "Pokud je datová sada obraz či mřížka, měla by tato vlastnost odpovídat rozestupu položek. Pro ostatní druhy prostorových datových sad bude tato vlastnost obvykle indikovat nejmenší vzdálenost mezi položkami této datové sady."
      },
      {
        "@language": "da",
        "@value": "Alternative geografiske opløsninger kan leveres som forskellige datasætdistributioner."
      },
      {
        "@language": "es",
        "@value": "Si el conjunto de datos es una imágen o grilla, esta propiedad corresponde al espaciado de los elementos. Para otro tipo de conjunto de datos espaciales, esta propieda usualmente indica la menor distancia entre los elementos de dichos datos."
      },
      {
        "@language": "it",
        "@value": "Se il set di dati è un'immagine o una griglia, questo dovrebbe corrispondere alla spaziatura degli elementi. Per altri tipi di set di dati spaziali, questa proprietà di solito indica la distanza minima tra gli elementi nel set di dati."
      },
      {
        "@language": "en",
        "@value": "If the dataset is an image or grid this should correspond to the spacing of items. For other kinds of spatial dataset, this property will usually indicate the smallest distance between items in the dataset."
      },
      {
        "@language": "da",
        "@value": "Hvis datasættet udgøres af et billede eller et grid, så bør dette svare til afstanden mellem elementerne. For andre typer af spatiale datasæt, vil denne egenskab typisk indikere den mindste afstand mellem elementerne i datasættet."
      },
      {
        "@language": "cs",
        "@value": "Různá prostorová rozlišení mohou být poskytována jako různé distribuce datové sady."
      },
      {
        "@language": "es",
        "@value": "Distintas distribuciones de un conjunto de datos pueden tener resoluciones espaciales diferentes."
      }
    ]
  },
