      {
        "@language": "en",
        "@value": "Note that, while most if not all Acts of Appraisal involve some estimating and many Acts of Estimation involve some appraising (i.e. these classes are not disjoint), neither class subsumes the other. For example, some Acts of Appraisal (e.g. a tax assessor appraising the value of a building) impart a normative element to the measured value while others (e.g. a gustatory appraisal that fresh green beans taste better than canned green beans) involve complete information. Furthermore, many Acts of Estimation (e.g. estimating the height of a tree) are concerned solely with determining a numerical value (as opposed to the nature, value, importance, condition, or quality)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Act of Appraisal"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00000345"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "An Act of Measuring that involves evaluating, assessing, estimating, or judging the nature, value, importance, condition, or quality of something or someone."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "a food critic rating the quality of a restaurant's ambiance, service, and food"
      },
      {
        "@value": "an insurance agent appraising the financial value of a building"
      },
      {
        "@value": "a mechanic assessing whether a damaged vehicle is repairable"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "In the context of an Act of Appraisal, the terms 'value', 'condition', and 'quality' do not have the same meanings as their counterparts that are defined in the Common Core Ontologies. For example, a knife may be appraised to be of high quality if it is sharp and sturdy or to be of inferior quality if it is dull or fragile."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://www.commoncoreontologies.org/EventOntology"
      }
    ]
  },
  {
    "@id": "http://www.ontologyrepository.com/CommonCoreOntologies/CybersecurityInfraction",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://purl.org/dc/terms/creator": [
      {
        "@language": "en",
        "@value": "CUBRC Inc"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Cybersecurity Infraction"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://www.ontologyrepository.com/CommonCoreOntologies/CybersecurityAct"
      }
    ],
    "http://www.w3.org/2002/07/owl#equivalentClass": [
      {
        "@id": "_:nf80cdc07e044424c93853a9c46ec024eb63"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@language": "en",
        "@value": "Cybersecurity Escape"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Cybersecurity Act that decreases the security of a Computer Network by creating a new Cyber Vulnerability or increasing an existing Cyber Vulnerability that inheres in that Computer Network."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@language": "en",
        "@value": "creating a weak password or reusing passwords"
      },
      {
        "@language": "en",
        "@value": "failing to set appropriate network access permissions"
      },
      {
        "@language": "en",
        "@value": "leaving a networked device unlocked and unattended in a public space"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "This class is designed to disambiguate between Cyber Acts that MIGHT cause damage (i.e., Cybersecurity Infraction) from Cyber Acts that DO cause damage (i.e., Cybersecurity Incident)."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"
      }
    ]
  },
