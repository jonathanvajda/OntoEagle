  {
    "@id": "https://github.com/jonathanvajda/cco-d-acts/ont00000001",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Originally a subclass of document (a subclass of Information Content Entity). Since it takes an input, Information Bearing Artifact is a better genus."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Document Act Input Document"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00001298"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Document that is intended to be the specified input in a Deontic Document Act. It has a Plan Specification as a part that specifies the intended socio-legal entities that are created through the document (objective specification) and the way in which the Deontic Document Act is to be performed (by signing, by stamping, etc.) (action specification)."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@language": "en",
        "@value": "A marriage license that is intended to be used in the documented solemnization of marital vows."
      },
      {
        "@language": "en",
        "@value": "An informed consent form that is intended to have a subject's PII data fields filled in."
      },
      {
        "@language": "en",
        "@value": "A loan application form that is not yet filled with personal and financial information."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001754": [
      {
        "@language": "en",
        "@value": "Modified, originally from Mathias Brochhausen (D-Acts Ontology), http://purl.obolibrary.org/obo/IAO_0021007"
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://github.com/jonathanvajda/cco-d-acts"
      }
    ],
    "https://www.commoncoreontologies.org/ont00001762": [
      {
        "@language": "en",
        "@value": "Jonathan M. Vajda"
      }
    ]
  },
  {
    "@id": "http://www.w3.org/2002/07/owl#targetIndividual",
    "@type": [
      "http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"
    ],
