  {
    "@id": "http://www.w3.org/ns/dcat#byteSize",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty",
      "http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "The size of a distribution in bytes."
      },
      {
        "@language": "it",
        "@value": "La dimensione di una distribuzione in byte."
      },
      {
        "@language": "cs",
        "@value": "Velikost distribuce v bajtech."
      },
      {
        "@language": "fr",
        "@value": "La taille de la distribution en octects"
      },
      {
        "@language": "ar",
        "@value": "الحجم بالبايتات "
      },
      {
        "@language": "ja",
        "@value": "バイトによる配信のサイズ。"
      },
      {
        "@language": "el",
        "@value": "Το μέγεθος μιας διανομής σε bytes."
      },
      {
        "@language": "da",
        "@value": "Størrelsen af en distributionen angivet i bytes."
      },
      {
        "@language": "es",
        "@value": "El tamaño de una distribución en bytes."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "http://www.w3.org/ns/dcat#Distribution"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://www.w3.org/TR/vocab-dcat/"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "byte size"
      },
      {
        "@language": "fr",
        "@value": "taille en octects"
      },
      {
        "@language": "it",
        "@value": "dimensione in byte"
      },
      {
        "@language": "cs",
        "@value": "velikost v bajtech"
      },
      {
        "@language": "es",
        "@value": "tamaño en bytes"
      },
      {
        "@language": "el",
        "@value": "μέγεθος σε bytes"
      },
      {
        "@language": "ja",
        "@value": "バイト・サイズ"
      },
      {
        "@language": "ar",
        "@value": "الحجم بالبايت"
      },
      {
        "@language": "da",
        "@value": "bytestørrelse"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2000/01/rdf-schema#Literal"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "ja",
        "@value": "バイトによる配信のサイズ。"
      },
      {
        "@language": "es",
        "@value": "El tamaño de una distribución en bytes."
      },
      {
        "@language": "el",
        "@value": "Το μέγεθος μιας διανομής σε bytes."
      },
      {
        "@language": "en",
        "@value": "The size of a distribution in bytes."
      },
      {
        "@language": "da",
        "@value": "Størrelsen af en distribution angivet i bytes."
      },
      {
        "@language": "it",
        "@value": "La dimensione di una distribuzione in byte."
      },
      {
        "@language": "cs",
        "@value": "Velikost distribuce v bajtech."
      },
      {
        "@language": "fr",
        "@value": "La taille de la distribution en octects."
      },
      {
        "@language": "ar",
        "@value": "الحجم بالبايتات "
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "cs",
        "@value": "Velikost v bajtech může být přibližná, pokud její přesná hodnota není známa. Literál s hodnotou dcat:byteSize by měl mít datový typ xsd:decimal."
      },
      {
        "@language": "it",
        "@value": "La dimensione in byte può essere approssimata quando non si conosce la dimensione precisa. Il valore di dcat:byteSize dovrebbe essere espresso come un xsd:decimal."
      },
      {
        "@language": "ja",
        "@value": "正確なサイズが不明である場合、サイズは、バイトによる近似値を示すことができます。"
      },
      {
        "@language": "ar",
        "@value": "الحجم يمكن أن يكون تقريبي إذا كان الحجم الدقيق غير معروف"
      },
      {
        "@language": "el",
        "@value": "Το μέγεθος σε bytes μπορεί να προσεγγιστεί όταν η ακριβής τιμή δεν είναι γνωστή. Η τιμή της dcat:byteSize θα πρέπει να δίνεται με τύπο δεδομένων xsd:decimal."
      },
      {
        "@language": "fr",
        "@value": "La taille en octects peut être approximative lorsque l'on ignore la taille réelle. La valeur littérale de dcat:byteSize doit être de type xsd:decimal."
      },
      {
        "@language": "en",
        "@value": "The size in bytes can be approximated when the precise size is not known. The literal value of dcat:byteSize should by typed as xsd:decimal."
      },
      {
        "@language": "es",
        "@value": "El tamaño en bytes puede ser aproximado cuando se desconoce el tamaño exacto. El valor literal de dcat:byteSize debe tener tipo 'xsd:decimal'."
      },
      {
        "@language": "da",
        "@value": "Bytestørrelsen kan approximeres hvis den præcise størrelse ikke er kendt. Værdien af dcat:byteSize bør angives som xsd:decimal."
      }
    ]
  },
  {
    "@id": "https://www.commoncoreontologies.org/ont00001330",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Telemetry Process"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00000110"
      },
      {
        "@id": "_:n0fa656c7a8f8475da75df9da57ada584b76"
      },
      {
        "@id": "_:n0fa656c7a8f8475da75df9da57ada584b77"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Mechanical Process that is highly automated and in which measurements are made or other data is collected and transmitted to receiving equipment to facilitate the monitoring of environmental conditions or equipment parameters at a remote or inaccessible location."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "using a portable cardiac monitor to remotely collect data on a patient's heart activity (biotelemetry)"
      },
      {
        "@value": "using a GPS tag to track a shark's migratory pattern"
      }
    ],
    "https://www.commoncoreontologies.org/ont00001754": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://en.wikipedia.org/w/index.php?title=Telemetry&oldid=1061697851"
      }
    ],
