  {
    "@id": "http://www.ontologyrepository.com/CommonCoreOntologies/StasisOfDigitalStorage",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Stasis of Digital Storage"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://www.ontologyrepository.com/CommonCoreOntologies/StasisOfInformationConcretization"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Stasis of Information Bearing that has as participants some Digital Storage Device and some Information Quality Entity."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "The purpose of this Stasis is to represent that some Digital Storage Device (e.g., a hard drive or RAM) stores (at a given time) a Computer Program. We cannot say that a Computer Program (an IBA) is part_of some hard drive or RAM, because although the hard drive or RAM might take on qualities in order to encode the Program, the Program itself is not identical to any of those qualities."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"
      }
    ]
  },
  {
    "@id": "https://www.commoncoreontologies.org/ont00000829",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Standards of date, time, and time zone data formats:\nISO/WD 8601-2 (http://www.loc.gov/standards/datetime/iso-tc154-wg5_n0039_iso_wd_8601-2_2016-02-16.pdf)\nW3C (https://www.w3.org/TR/NOTE-datetime)"
      },
      {
        "@language": "en",
        "@value": "There is no class 'Time Zone' (the region), only 'Time Zone Identifier' (the designator for some region). Instances of 'Time Zone Identifier' should be related to instances of 'Information Bearing Entity' by means of the object properites 'uses time zone identifier' and 'time zone identifier used by' as appropriate. This is supposed to be analogous to the way we represent the relationship between measurement values and measurement units, where the relevant instance of Information Bearing Entity 'uses measurement unit' some instance of Measurement Unit (i.e., an instance of Information Content Entity)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Time Zone Identifier"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00000390"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Spatial Region Identifier that designates the region associated with some uniform standard time for legal, commercial, or social purposes."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://www.commoncoreontologies.org/InformationEntityOntology"
      }
    ]
  },
