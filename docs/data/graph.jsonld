      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "Instances of this class can be combined with instances of other classes to represent various TCP states, including: CLOSE WAIT, CLOSING, FIN-WAIT-1, FIN-WAIT-2, LAST ACK, SYN RECEIVED, SYN SENT, and TIME WAIT."
      }
    ],
