      }
    ],
    "http://www.w3.org/2002/07/owl#equivalentProperty": [
      {
        "@id": "http://purl.org/pav/hasCurrentVersion"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#changeNote": [
      {
        "@language": "en",
        "@value": "New property added in DCAT 3."
      },
      {
        "@language": "it",
        "@value": "Nuova proprietà aggiunta in DCAT 3."
      },
      {
        "@language": "es",
        "@value": "Nueva propiedad agregada in DCAT 3."
      },
      {
        "@language": "cs",
        "@value": "Nová vlastnost přidaná ve verzi DCAT 3."
      },
      {
        "@language": "da",
        "@value": "Ny egenskab tilføjet i DCAT 3."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "This resource has a more specific, versioned resource with equivalent content [PAV]."
      },
      {
        "@language": "es",
        "@value": "Este recurso es más específico y versionado con contenido equivalente [PAV]."
      },
      {
        "@language": "it",
        "@value": "Per questa risorsa esiste una risorsa più specifica e versionata, ma con lo stesso contenuto."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Esta propepiedad está destinada a relacionar un recurso no versionado o abstracto con una versión instantánea que puede usarse como un enlace permanente a la versión actual del recurso [PAV]."
      },
      {
        "@language": "en",
        "@value": "This property is intended for relating a non-versioned or abstract resource to a single snapshot that can be used as a permalink to indicate the current version of the content [PAV]."
      },
      {
        "@language": "es",
        "@value": "La noción de versión que se usa en esta propiedad está limitada a las versiones que resultan de revisiones de un recurso como parte de su ciclo de vida."
      },
      {
        "@language": "it",
        "@value": "Questa proprietà è usata per correlare una risorsa non versionata o astratta a un suo specifico snapshot che può essere usato come permalink per indicare la versione attuale del suo contenuto."
      },
      {
        "@language": "en",
        "@value": "The notion of version used by this property is limited to versions resulting from revisions occurring to a resource as part of its life-cycle."
      },
      {
        "@language": "it",
        "@value": "La nozione di versione usata da questa proprietà è limitata a versioni risultanti da revisioni a cui una risorsa è soggetta nel suo ciclo di vita."
      }
    ]
  },
