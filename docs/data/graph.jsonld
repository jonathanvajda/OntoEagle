  {
    "@id": "http://www.w3.org/ns/dcat#DatasetSeries",
    "@type": [
      "http://www.w3.org/2000/01/rdf-schema#Class",
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "es",
        "@value": "Una colección de conjuntos de datos publicados por separado, pero que comparten características que los agrupan."
      },
      {
        "@language": "it",
        "@value": "Una collezione di dataset che sono pubblicati separatamente, ma che condividono caratteristiche che li rendono parte di uno stesso gruppo."
      },
      {
        "@language": "en",
        "@value": "A collection of datasets that are published separately, but share some characteristics that group them."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://www.w3.org/TR/vocab-dcat-3/"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "es",
        "@value": "Serie de conjuntos de datos"
      },
      {
        "@language": "en",
        "@value": "Dataset series"
      },
      {
        "@language": "it",
        "@value": "Serie di dataset"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://www.w3.org/ns/dcat#Dataset"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#changeNote": [
      {
        "@language": "da",
        "@value": "Ny klasse tilføjet i DCAT 3"
      },
      {
        "@language": "es",
        "@value": "Nueva clase agregada en DCAT 3."
      },
      {
        "@language": "it",
        "@value": "Nuova classe aggiunta in DCAT 3"
      },
      {
        "@language": "cs",
        "@value": "Nová třída přidaná ve verzi DCAT 3"
      },
      {
        "@language": "en",
        "@value": "New class added in DCAT 3."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A collection of datasets that are published separately, but share some common characteristics that groups them."
      },
      {
        "@language": "it",
        "@value": "Una collezione di dataset che sono pubblicati separatamente, ma che condividono caratteristiche che li rendono parte di uno stesso gruppo."
      },
      {
        "@language": "es",
        "@value": "Una colección de conjuntos de datos publicados por separado, pero que comparten características comunes que los agrupan."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#editorialNote": [
      {
        "@language": "en",
        "@value": "2022-05-08 Added to ttl file with annotations in English, Spanish and Italian, except notes that are in other languages too."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "Dataset series can be also soft-typed via property dcterms:type as in the approach used in [GeoDCAT-AP], and adopted in [DCAT-AP-IT] and [GeoDCAT-AP-IT])."
      },
      {
        "@language": "it",
        "@value": "Scenari tipici per l'uso di serie di dataset: serie temporali costituite di dataset pubblicati regolarmente; serie di mappe costituite da elementi dello stesso tipo o tematica ma relative a differenti aree geografiche."
      },
      {
        "@language": "it",
        "@value": "Le serie di dati possono anche essere denotate come tali usando la proprietà dcterms:type, secondo l'approccio usato in [GeoDCAT-AP], e adottato in [DCAT-AP-IT] e [GeoDCAT-AP-IT])."
      },
      {
        "@language": "es",
        "@value": "Algunos escenarios comunes para series de conjuntos de datos son: series temporales compuestas de subconjuntos de datos publicados periódicamente; series de mapas compuestos de elementos del mismo tipo o tema pero con distintas huellas espaciales."
      },
      {
        "@language": "en",
        "@value": "Common scenarios for dataset series include: time series composed of periodically released subsets; map-series composed of items of the same type or theme but with differing spatial footprints."
      },
      {
        "@language": "es",
        "@value": "También puede asignarse un tipo a las series de datos usando la propiedad dcterms:type como se hace en [GeoDCAT-AP], y adoptado en [DCAT-AP-IT] y [GeoDCAT-AP-IT])."
      }
    ]
  },
