      "http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "La versione precedente di una risorsa."
      },
      {
        "@language": "en",
        "@value": "The previous version of a resource in a lineage [PAV]."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://www.w3.org/TR/vocab-dcat-3/"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "versione precedente"
      },
      {
        "@language": "en",
        "@value": "previous version"
      },
      {
        "@language": "es",
        "@value": "versión anterior"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "http://www.w3.org/ns/prov#wasRevisionOf"
      }
    ],
    "http://www.w3.org/2002/07/owl#equivalentProperty": [
      {
        "@id": "http://purl.org/pav/previousVersion"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#changeNote": [
      {
        "@language": "en",
        "@value": "New property added in DCAT 3."
      },
      {
        "@language": "it",
        "@value": "Nuova proprietà aggiunta in DCAT 3."
      },
      {
        "@language": "es",
        "@value": "Nueva propiedad agregada in DCAT 3."
      },
      {
        "@language": "cs",
        "@value": "Nová vlastnost přidaná ve verzi DCAT 3."
      },
      {
        "@language": "da",
        "@value": "Ny egenskab tilføjet i DCAT 3."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "it",
        "@value": "La versione precedente di una risorsa."
      },
      {
        "@language": "en",
        "@value": "The previous version of a resource in a lineage [PAV]."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "The notion of version used by this property is limited to versions resulting from revisions occurring to a resource as part of its life-cycle. One of the typical cases here is representing the history of the versions of a dataset that have been released over time."
      },
      {
        "@language": "en",
        "@value": "This property is meant to be used to specify a version chain, consisting of snapshots of a resource."
      },
      {
        "@language": "it",
        "@value": "La nozione di versione usata da questa proprietà è limitata a versioni risultanti da revisioni a cui una risorsa è soggetta nel suo ciclo di vita. Uno dei casi tipici è la rappresentazione della storia delle versioni di un dataset, che sono state pubblicate nel corso del tempo."
      },
      {
        "@language": "it",
        "@value": "Questa proprietà è usata per specificare una catena di versioni, costituita da snapshot di una risorsa."
      }
    ]
  },
