  {
    "@id": "http://www.ontologyrepository.com/CommonCoreOntologies/CybersecurityViolation",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://purl.org/dc/terms/creator": [
      {
        "@language": "en",
        "@value": "CUBRC Inc"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Creating an equivalency axiom for Cybersecurity Violation requires creating a term such as 'Cybersecurity Policy'."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Cybersecurity Violation"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://www.ontologyrepository.com/CommonCoreOntologies/CybersecurityAct"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Cybersecurity Act that violates the Computer Network owner's Cybersecurity Policy."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@language": "en",
        "@value": "using a secure information system to access a personal social media account"
      },
      {
        "@language": "en",
        "@value": "failing to follow the exact steps outlined by the security policy for a procedure"
      },
      {
        "@language": "en",
        "@value": "plugging an unapproved device into a company computer"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "Cybersecurity Violations are differentiated from Cybersecurity Infractions because violations are specific to organizational policies. Not every act that violates a Cybersecurity Policy necessarily has a negative effect on the security of a Computer Network. Similarly, it is unlikely that any given Cybersecurity Policy is capable of documenting every possible action that would negatively affect a Computer Network. Hence, these classes are distinct despite having many instances in common."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"
      }
    ]
  },
