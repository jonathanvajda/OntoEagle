      {
        "@id": "_:n35f7ea81f0274106b1c8e28a018c4b51b95"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Material Entity that bears an Agent Capability."
      }
    ],
