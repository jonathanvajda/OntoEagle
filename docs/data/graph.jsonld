    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Combustion Engine that is designed to have an external Combustion Chamber where portions of Fuel and Oxidizer mixture are burned to generate thermal energy to heat the working fluid, which transfers energy to the Engine where it is converted into mechanical energy."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001754": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
