  {
    "@id": "http://www.w3.org/ns/dcat#theme",
    "@type": [
      "http://www.w3.org/1999/02/22-rdf-syntax-ns#Property",
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "ar",
        "@value": "التصنيف الرئيسي لقائمة البيانات. قائمة البيانات يمكن أن تملك أكثر من تصنيف رئيسي واحد."
      },
      {
        "@language": "en",
        "@value": "A main category of the resource. A resource can have multiple themes."
      },
      {
        "@language": "el",
        "@value": "Η κύρια κατηγορία του συνόλου δεδομένων. Ένα σύνολο δεδομένων δύναται να έχει πολλαπλά θέματα."
      },
      {
        "@language": "ja",
        "@value": "データセットの主要カテゴリー。データセットは複数のテーマを持つことができます。"
      },
      {
        "@language": "es",
        "@value": "La categoría principal del recurso. Un recurso puede tener varios temas."
      },
      {
        "@language": "da",
        "@value": "Et centralt emne for ressourcen. En ressource kan have flere centrale emner."
      },
      {
        "@language": "it",
        "@value": "La categoria principale della risorsa. Una risorsa può avere più temi."
      },
      {
        "@language": "cs",
        "@value": "Hlavní téma zdroje. Zdroj může mít více témat."
      },
      {
        "@language": "fr",
        "@value": "La catégorie principale de la ressource. Une ressource peut avoir plusieurs thèmes."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://www.w3.org/TR/vocab-dcat/"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "tema"
      },
      {
        "@language": "da",
        "@value": "emne"
      },
      {
        "@language": "es",
        "@value": "tema"
      },
      {
        "@language": "ja",
        "@value": "テーマ/カテゴリー"
      },
      {
        "@language": "en",
        "@value": "theme"
      },
      {
        "@language": "ar",
        "@value": "التصنيف"
      },
      {
        "@language": "el",
        "@value": "Θέμα"
      },
      {
        "@language": "cs",
        "@value": "téma"
      },
      {
        "@language": "fr",
        "@value": "thème"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "http://purl.org/dc/terms/subject"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@language": "da",
        "@value": "tema"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "ja",
        "@value": "データセットの主要カテゴリー。データセットは複数のテーマを持つことができます。"
      },
      {
        "@language": "es",
        "@value": "La categoría principal del recurso. Un recurso puede tener varios temas."
      },
      {
        "@language": "da",
        "@value": "Et centralt emne for ressourcen. En ressource kan have flere centrale emner."
      },
      {
        "@language": "it",
        "@value": "La categoria principale della risorsa. Una risorsa può avere più temi."
      },
      {
        "@language": "cs",
        "@value": "Hlavní téma zdroje. Zdroj může mít více témat."
      },
      {
        "@language": "fr",
        "@value": "La catégorie principale de la ressource. Une ressource peut avoir plusieurs thèmes."
      },
      {
        "@language": "ar",
        "@value": "التصنيف الرئيسي لقائمة البيانات. قائمة البيانات يمكن أن تملك أكثر من تصنيف رئيسي واحد."
      },
      {
        "@language": "en",
        "@value": "A main category of the resource. A resource can have multiple themes."
      },
      {
        "@language": "el",
        "@value": "Η κύρια κατηγορία του συνόλου δεδομένων. Ένα σύνολο δεδομένων δύναται να έχει πολλαπλά θέματα."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#editorialNote": [
      {
        "@language": "en",
        "@value": "Status: English Definition text  modified by DCAT revision team, all except for Italian and Czech translations are pending. Scope note has changed and its translations should be updated"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "da",
        "@value": "Samlingen af begreber (skos:Concept) der anvendes til at emneinddele ressourcer organiseres i et begrebssystem (skos:ConceptScheme) som beskriver alle emnerne og deres relationer i kataloget."
      },
      {
        "@language": "es",
        "@value": "El conjunto de skos:Concepts utilizados para categorizar los recursos están organizados en un skos:ConceptScheme que describe todas las categorías y sus relaciones en el catálogo."
      },
      {
        "@language": "en",
        "@value": "The set of themes used to categorize the resources are organized in a skos:ConceptScheme, skos:Collection, owl:Ontology or similar, describing all the categories and their relations in the catalog."
      },
      {
        "@language": "cs",
        "@value": "Sada instancí třídy skos:Concept použitá pro kategorizaci zdrojů je organizována do schématu konceptů skos:ConceptScheme, které popisuje všechny kategorie v katalogu a jejich vztahy."
      },
      {
        "@language": "el",
        "@value": "Το σετ των skos:Concepts που χρησιμοποιείται για να κατηγοριοποιήσει τα σύνολα δεδομένων είναι οργανωμένο εντός ενός skos:ConceptScheme που περιγράφει όλες τις κατηγορίες και τις σχέσεις αυτών στον κατάλογο."
      },
      {
        "@language": "fr",
        "@value": "Un ensemble de skos:Concepts utilisés pour catégoriser les ressources sont organisés en un skos:ConceptScheme décrivant toutes les catégories et ses relations dans le catalogue."
      },
      {
        "@language": "ja",
        "@value": "データセットを分類するために用いられるskos:Conceptの集合は、カタログのすべてのカテゴリーとそれらの関係を記述しているskos:ConceptSchemeで組織化されます。"
      },
      {
        "@language": "it",
        "@value": "Il set di concetti skos usati per categorizzare le risorse sono organizzati in skos:ConceptScheme che descrive tutte le categorie e le loro relazioni nel catalogo."
      }
    ]
  },
