      }
    ],
    "http://www.w3.org/2004/02/skos/core#changeNote": [
      {
        "@language": "en",
        "@value": "New property added in DCAT 3."
      },
      {
        "@language": "it",
        "@value": "Nuova proprietà aggiunta in DCAT 3."
      },
      {
        "@language": "es",
        "@value": "Nueva propiedad agregada in DCAT 3."
      },
      {
        "@language": "cs",
        "@value": "Nová vlastnost přidaná ve verzi DCAT 3."
      },
      {
        "@language": "da",
        "@value": "Ny egenskab tilføjet i DCAT 3."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "The last resource in an ordered collection or series of resources, to which the current resource belongs."
      },
      {
        "@language": "es",
        "@value": "El último recurso en una colección ordenada o serie de recursos, al que el recurso pertenece."
      },
      {
        "@language": "it",
        "@value": "L'ultima risorsa in una collezione ordinata o in una serie di risorse, di cui la risorsa fa parte."
