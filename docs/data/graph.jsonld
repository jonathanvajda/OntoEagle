  {
    "@id": "http://purl.obolibrary.org/obo/BFO_0000176",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://purl.org/dc/elements/1.1/identifier": [
      {
        "@value": "221-BFO"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "http://purl.obolibrary.org/obo/BFO_0000002"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "continuant part of"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://purl.obolibrary.org/obo/BFO_0000002"
      }
    ],
    "http://www.w3.org/2002/07/owl#inverseOf": [
      {
        "@id": "http://purl.obolibrary.org/obo/BFO_0000178"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "b continuant part of c =Def b and c are continuants & there is some time t such that b and c exist at t & b continuant part of c at t"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@language": "en",
        "@value": "Milk teeth continuant part of human; surgically removed tumour continuant part of organism"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: <https://github.com/BFO-ontology/BFO-2020/tree/master/src/owl/profiles/temporal%20extensions>"
      }
    ]
  },
  {
