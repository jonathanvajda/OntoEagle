    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "it",
        "@value": "Il sistema di organizzazione della conoscenza (KOS) usato per classificare i dataset del catalogo."
      },
      {
        "@language": "ar",
        "@value": "لائحة التصنيفات المستخدمه لتصنيف قوائم البيانات ضمن الفهرس"
      },
      {
        "@language": "fr",
        "@value": "Le systhème d'ogranisation de connaissances utilisé pour classifier les jeux de données du catalogue."
      },
      {
        "@language": "en",
        "@value": "The knowledge organization system (KOS) used to classify catalog's datasets."
