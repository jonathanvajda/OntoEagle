      {
        "@language": "en",
        "@value": "An Act of Position Change does not entail a change of location."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Act of Position Change"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00000357"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "An Act of Motion in which the position (i.e. the orientation, alignment, or arrangement) of some Object or of one or more of an Object's parts is changed by some Agent."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "a top spinning in place"
      },
      {
        "@value": "swivelling your office chair to face the window"
      },
      {
        "@value": "adjusting your posture"
      },
      {
        "@value": "raising your left arm"
      }
    ],
