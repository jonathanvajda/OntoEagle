  {
    "@id": "https://www.commoncoreontologies.org/ont00001916",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00000686"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "designates"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00001808"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "x designates y iff x is an instance of an Information Content Entity, and y is an instance of an Entity, such that given some context, x uniquely distinguishes y from other entities."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "a URL designates the location of a Web Page on the internet"
      },
      {
        "@value": "a vehicle identification number designates some vehicle"
      },
      {
        "@value": "a person's name designates that person"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "Given a stronger temporal interpretation, this property may be functional. For more info please refer to https://github.com/BFO-ontology/BFO-2020/tree/master/src/owl/temporal%20extensions."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://www.commoncoreontologies.org/InformationEntityOntology"
      }
    ]
  },
