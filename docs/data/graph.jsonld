  {
    "@id": "https://www.commoncoreontologies.org/ont00001862",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "http://purl.obolibrary.org/obo/BFO_0000038"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "interval disjoint"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://purl.obolibrary.org/obo/BFO_0000038"
      }
    ],
    "http://www.w3.org/2002/07/owl#propertyDisjointWith": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00001870"
      },
      {
        "@id": "https://www.commoncoreontologies.org/ont00001924"
      },
      {
        "@id": "https://www.commoncoreontologies.org/ont00001971"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Temporal Interval INT1 is disjoint with a Temporal Interval INT2 iff INT1 is before or meets INT2 OR INT2 is before or meets INT1. In other words, INT1 and INT2 are disjoint iff INT1 and INT2 do not overlap, contain, or equal one another."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001754": [
      {
        "@language": "en",
        "@value": "J. F. Allen and J. A. G. M. Koomen. Planning using a temporal world model. In Proceedings of the 8th International Joint Conference on Artificial Intelligence (IJCAI-1983)  pages 741–747. Available at: https://www.ijcai.org/Proceedings/83-2/Papers/036.pdf"
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://www.commoncoreontologies.org/TimeOntology"
      }
    ]
  },
  {
    "@id": "http://www.w3.org/ns/dcat#Catalog",
    "@type": [
      "http://www.w3.org/2000/01/rdf-schema#Class",
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "fr",
        "@value": "Une collection élaborée de métadonnées sur les jeux de données"
      },
      {
        "@language": "da",
        "@value": "En udvalgt og arrangeret samling af metadata om ressourcer (fx datasæt og datatjenester i kontekst af et datakatalog). "
      },
      {
        "@language": "it",
        "@value": "Una raccolta curata di metadati sulle risorse (ad es. sui dataset e relativi servizi nel contesto di cataloghi di dati)."
      },
      {
        "@language": "ja",
        "@value": "データ・カタログは、データセットに関するキュレートされたメタデータの集合です。"
      },
      {
        "@language": "en",
        "@value": "A curated collection of metadata about resources (e.g., datasets and data services in the context of a data catalog)."
      },
      {
        "@language": "el",
        "@value": "Μια επιμελημένη συλλογή μεταδεδομένων περί συνόλων δεδομένων"
      },
      {
        "@language": "ar",
        "@value": "مجموعة من توصيفات قوائم البيانات"
      },
      {
        "@language": "cs",
        "@value": "Řízená kolekce metadat o datových sadách a datových službách"
      },
      {
        "@language": "es",
