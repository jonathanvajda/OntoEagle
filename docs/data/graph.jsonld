  {
    "@id": "http://www.w3.org/ns/dcat#hasVersion",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty",
      "http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "This resource has a more specific, versioned resource [PAV]."
      },
      {
        "@language": "it",
        "@value": "Per questa risorsa esiste una risorsa più specifica e versionata."
      },
      {
        "@language": "es",
        "@value": "Este recurso tiene una versión específica."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://www.w3.org/TR/vocab-dcat-3/"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "ha versione"
      },
      {
        "@language": "es",
        "@value": "tiene versión"
      },
      {
        "@language": "en",
        "@value": "has version"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "http://www.w3.org/ns/prov#generalizationOf"
      },
      {
        "@id": "http://purl.org/dc/terms/hasVersion"
      }
    ],
    "http://www.w3.org/2002/07/owl#equivalentProperty": [
      {
        "@id": "http://purl.org/pav/hasVersion"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#changeNote": [
      {
        "@language": "it",
        "@value": "Nuova proprietà aggiunta in DCAT 3."
      },
      {
        "@language": "es",
        "@value": "Nueva propiedad agregada in DCAT 3."
      },
      {
        "@language": "cs",
        "@value": "Nová vlastnost přidaná ve verzi DCAT 3."
      },
      {
        "@language": "da",
        "@value": "Ny egenskab tilføjet i DCAT 3."
      },
      {
        "@language": "en",
        "@value": "New property added in DCAT 3."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "it",
        "@value": "Per questa risorsa esiste una risorsa più specifica e versionata."
      },
      {
        "@language": "es",
        "@value": "Este recurso tiene una versión específica."
      },
      {
        "@language": "en",
        "@value": "This resource has a more specific, versioned resource [PAV]."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "The notion of version used by this property is limited to versions resulting from revisions occurring to a resource as part of its life-cycle. Therefore, its semantics is more specific than its super-property dcterms:hasVersion, which makes use of a broader notion of version, including editions and adaptations."
      },
      {
        "@language": "en",
        "@value": "This property is intended for relating a non-versioned or abstract resource to several versioned resources, e.g., snapshots [PAV]."
      },
      {
        "@language": "it",
        "@value": "Questa proprietà è usata per correlare una risorsa non versionata o astratta a differenti risorse versionate, ad es., i relativi snapshot."
      },
      {
        "@language": "es",
        "@value": "Esta propiedad se utiliza para relacionar un recurso abstracto o no versionado de un recurso con varias versiones del recuros; por ejemplo, versiones intastáneas."
      },
      {
        "@language": "es",
        "@value": "La noción de versión que se usa en esta propiedad está limitada a las versiones que resultan de revisiones de un recurso como parte de su ciclo de vida. Por lo tanto, su semántica es más específica que su super-propiedad dcterns:hasVersion, la cuál hace uso de la noción más amplia de versión, incluyendo ediciones y adaptaciones."
      },
      {
        "@language": "it",
        "@value": "La nozione di versione usata da questa proprietà è limitata a versioni risultanti da revisioni a cui una risorsa è soggetta nel suo ciclo di vita. Quindi la sua semantica è più specifica di quella della sua super-proprietà dcterms:hasVersion, che utilizza una nozione di versione più ampia, e include, ad es., edizioni e adattamenti."
      }
    ]
  },
