  {
    "@id": "https://www.commoncoreontologies.org/ont00000379",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Examples: affirming, alleging, announcing, answering, attributing, claiming, classifying, concurring, confirming, conjecturing, denying, disagreeing, disclosing, disputing, identifying, informing, insisting, predicting, ranking, reporting, stating, stipulating"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Act of Representative Communication"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00000402"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "An Act of Communication that commits a speaker to the truth of the expressed proposition."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001754": [
      {
        "@value": "Derived (loosely) from: John Searle's Speech Acts: An Essay in the Philosophy of Language"
      }
    ],
