      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Material Artifact that is designed to process light waves."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "Light waves can be processed in a variety of ways including via reflection, refraction, diffraction, deflection, focusing, collimation, dispersion, and interference."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001754": [
      {
