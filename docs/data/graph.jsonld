  {
    "@id": "https://www.commoncoreontologies.org/ont00000558",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Visible Light Reflection Process"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00000099"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Wave Process in which an Electromagnetic Wave with a Visible Light Frequency is reflected off a portion of matter."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://www.commoncoreontologies.org/EventOntology"
      }
    ]
  },
  {
    "@id": "http://purl.obolibrary.org/obo/BFO_0000020",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://purl.org/dc/elements/1.1/identifier": [
      {
        "@value": "050-BFO"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "specifically dependent continuant"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://purl.obolibrary.org/obo/BFO_0000002"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "b is a specifically dependent continuant =Def b is a continuant & there is some independent continuant c which is not a spatial region & which is such that b specifically depends on c"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@language": "en",
        "@value": "(with one bearer) The mass of this tomato; the pink colour of a medium rare piece of grilled filet mignon at its centre; the smell of this portion of mozzarella; the disposition of this fish to decay; the role of being a doctor; the function of this heart to pump blood; the shape of this hole"
      },
      {
        "@language": "en",
        "@value": "(with multiple bearers) John's love for Mary; the ownership relation between John and this statue; the relation of authority between John and his subordinates"
      }
    ]
  },
