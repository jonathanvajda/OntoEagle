    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "Subclasses of Operating System Model are fiat collections that group families of related models based on the developer or a shared evolutionary history. It is reasonable to assume these classes are best considered as enumerations of all the known models that belong in that family or developmental history."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
