  {
    "@id": "http://www.ontologyrepository.com/CommonCoreOntologies/NetworkServiceFunction",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Network Service Function"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://www.ontologyrepository.com/CommonCoreOntologies/InformationProcessingArtifactFunction"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@language": "en",
        "@value": "Network Service"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "An Information Processing Artifact Function that when realized is in a process of a client accessing some other Information Processing Artifact Function, called a service, over a Computer Network."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "'Service' typically refers to the functionality of some program, or other resource, e.g., file management. The ability for a server to provide that functionality requires the existence of an additional function, which is what these classes are designed to represent. However, the service-enabling function is different from the service itself. Since many types of programs and other information processing artifacts can be offered as services, it doesn’t make sense to create duplicate terms for when an application is a service vs. when it isn’t. By analogy, consider a pizza restaurant that offers dine-in, take-out, and delivery options. These three modes of getting your pizza don’t make for three different kinds of pizza. Same pizza, same restaurant, different ways of accessing."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "http://www.ontologyrepository.com/CommonCoreOntologies/Domain/CyberOntology"
      }
    ]
  },
