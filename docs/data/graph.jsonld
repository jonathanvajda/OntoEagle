  {
    "@id": "http://www.w3.org/ns/dcat#servesDataset",
    "@type": [
      "http://www.w3.org/1999/02/22-rdf-syntax-ns#Property",
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Una raccolta di dati che questo DataService può distribuire."
      },
      {
        "@language": "es",
        "@value": "Una colección de datos que este Servicio de Datos puede distribuir."
      },
      {
        "@language": "da",
        "@value": "En samling af data som denne datatjeneste kan distribuere."
      },
      {
        "@language": "en",
        "@value": "A collection of data that this DataService can distribute."
