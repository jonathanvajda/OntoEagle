      {
        "@language": "en",
        "@value": "The submillimeter waveband is between the far-infrared and microwave wavebands and is typically taken to have a wavelength of between a few hundred micrometers and a millimeter."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Submillimeter Wavelength Radio Telescope"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00000215"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@language": "en",
        "@value": "Microwave Telescope"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Radio Telescope that is designed to aid in the observation of spatially distant Objects by means of collecting and focusing radio waves from the submillimeter waveband (i.e. microwaves) to form an enhanced image of the Object."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001754": [
      {
        "@value": "http://kp12m.as.arizona.edu/docs/what_is_submillimeter.htm, https://en.wikipedia.org/wiki/Submillimetre_astronomy"
      }
    ],
