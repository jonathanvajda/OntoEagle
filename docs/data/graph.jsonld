        "@language": "en",
        "@value": "socio-legally revokes"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "d socio-legally revokes s, if s participates in d and at the end of d s no longer exists."
      }
    ],
