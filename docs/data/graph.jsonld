    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "ja",
        "@value": "データ・カタログは、データセットに関するキュレートされたメタデータの集合です。"
      },
      {
        "@language": "ar",
        "@value": "مجموعة من توصيفات قوائم البيانات"
      },
      {
        "@language": "it",
        "@value": "Una raccolta curata di metadati sulle risorse."
      },
      {
        "@language": "da",
        "@value": "En samling af metadata om ressourcer."
      },
      {
        "@language": "es",
        "@value": "Una colección curada de metadatos sobre recursos."
      },
      {
        "@language": "en",
        "@value": "A curated collection of metadata about resources."
      },
      {
        "@language": "cs",
        "@value": "Řízená kolekce metadat o datových sadách a datových službách."
      },
      {
        "@language": "fr",
        "@value": "Une collection élaborée de métadonnées sur les jeux de données."
      },
      {
        "@language": "el",
        "@value": "Μια επιμελημένη συλλογή μεταδεδομένων περί συνόλων δεδομένων."
