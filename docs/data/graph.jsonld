    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "b is a relational quality =Def b is a quality & there exists c and d such that c and d are not identical & b specifically depends on c & b specifically depends on d"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@language": "en",
        "@value": "A marriage bond; an instance of love; an obligation between one person and another"
      }
