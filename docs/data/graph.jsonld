      },
      {
        "@language": "da",
        "@value": "datasæt"
      },
      {
        "@language": "el",
        "@value": "σύνολο δεδομένων"
      },
      {
        "@language": "fr",
        "@value": "jeu de données"
      },
      {
        "@language": "es",
        "@value": "conjunto de datos"
      },
      {
        "@language": "cs",
        "@value": "datová sada"
      }
    ],
