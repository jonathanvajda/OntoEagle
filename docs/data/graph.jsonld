  {
    "@id": "http://www.w3.org/ns/dcat#endDate",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty",
      "http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "da",
        "@value": "Slutningen på perioden."
      },
      {
        "@language": "es",
        "@value": "El fin del período."
      },
      {
        "@language": "en",
        "@value": "The end of the period."
      },
      {
        "@language": "cs",
        "@value": "Konec doby trvání."
      },
      {
        "@language": "it",
        "@value": "La fine del periodo."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "http://purl.org/dc/terms/PeriodOfTime"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://www.w3.org/TR/vocab-dcat-2/"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "cs",
        "@value": "datum konce"
      },
      {
        "@language": "da",
        "@value": "slutdato"
      },
      {
        "@language": "it",
        "@value": "data di fine"
      },
      {
        "@language": "en",
        "@value": "end date"
      },
      {
        "@language": "es",
        "@value": "fecha final"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2000/01/rdf-schema#Literal"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@language": "da",
        "@value": "sluttidspunkt"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#changeNote": [
      {
        "@language": "en",
        "@value": "New property added in DCAT 2."
      },
      {
        "@language": "cs",
        "@value": "Nová vlastnost přidaná ve verzi DCAT 2."
      },
      {
        "@language": "da",
        "@value": "Ny egenskab i DCAT 2."
      },
      {
        "@language": "it",
        "@value": "Nuova proprietà aggiunta in DCAT 2."
      },
      {
        "@language": "es",
        "@value": "Nueva propiedad agregada en DCAT 2."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "cs",
        "@value": "Konec doby trvání."
      },
      {
        "@language": "it",
        "@value": "La fine del periodo."
      },
      {
        "@language": "da",
        "@value": "Slutningen på perioden."
      },
      {
        "@language": "es",
        "@value": "El fin del período."
      },
      {
        "@language": "en",
        "@value": "The end of the period."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "cs",
        "@value": "Obor hodnot této vlastnosti je úmyslně obecný, aby umožnil různé úrovně časového rozlišení pro specifikaci konce doby trvání. Ten může být kupříkladu vyjádřen datumem (xsd:date), datumem a časem (xsd:dateTime) či rokem (xsd:gYear)."
      },
      {
        "@language": "es",
        "@value": "El rango de esta propiedad es intencionalmente genérico con el propósito de permitir distintos niveles de precisión temporal para especificar el fin del período. Por ejemplo, puede expresarse como una fecha (xsd:date), una fecha y un tiempo (xsd:dateTime), o un año (xsd:gYear)."
      },
      {
        "@language": "it",
        "@value": "La range di questa proprietà è volutamente generico, con lo scopo di consentire diversi livelli di precisione temporale per specificare la fine di un periodo. Ad esempio, può essere espresso con una data (xsd:date), una data e un'ora (xsd:dateTime), o un anno (xsd:gYear)."
      },
      {
        "@language": "en",
        "@value": "The range of this property is intentionally generic, with the purpose of allowing different level of temporal precision for specifying the end of a period. E.g., it can be expressed with a date (xsd:date), a date and time (xsd:dateTime), or a year (xsd:gYear)."
      },
      {
        "@language": "da",
        "@value": "Rækkeviden for denne egenskab er bevidst generisk defineret med det formål at tillade forskellige niveauer af tidslig præcision ifm. angivelse af slutdatoen for en periode. Den kan eksempelvis udtrykkes som en dato (xsd:date), en dato og et tidspunkt (xsd:dateTime), eller et årstal (xsd:gYear)."
      }
    ]
  },
  {
    "@id": "https://www.commoncoreontologies.org/ont00001660",
    "@type": [
      "https://www.commoncoreontologies.org/ont00000469",
      "http://www.w3.org/2002/07/owl#NamedIndividual"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "This global main field model provides magnetic field values for any location on Earth, e.g. for  navigational purposes (declination) or as a standard for core field subtraction for aeromagnetic surveys. An updated version is adopted by International Association of Geomagnetism and Aeronomy (IAGA) every 5 years)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "International Geomagnetic Reference Field"
      }
    ],
    "https://www.commoncoreontologies.org/ont00001754": [
      {
        "@value": "Alken, P., Thébault, E., Beggan, C.D. et al. International Geomagnetic Reference Field: the thirteenth generation. Earth Planets Space 73, 49 (2021). https://doi.org/10.1186/s40623-020-01288-x , https://www.iaga-aiga.org/"
      }
    ]
  },
