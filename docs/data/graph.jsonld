  {
    "@id": "https://www.commoncoreontologies.org/ont00000140",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "The type of particle quantified is typically either atoms or molecules, but may also be protons, neutrons, electrons, quarks, or other particles. The type of particle being measured should always be specified along with the measurement and its unit."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Measurement Unit of Amount of Substance"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00000120"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@language": "en",
        "@value": "Measurement Unit of Chemical Amount"
      },
      {
        "@language": "en",
        "@value": "Measurement Unit of Enplethy"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Measurement Unit that is used as a standard for measurement of the number of a specified type of particle in a portion of matter."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "mole, pound-mole"
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
      {
        "@value": "https://www.commoncoreontologies.org/UnitsOfMeasureOntology"
      }
    ]
  },
