  {
    "@id": "https://github.com/jonathanvajda/cco-d-acts",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology"
    ],
    "http://purl.org/dc/elements/1.1/title": [
      {
        "@language": "en",
        "@value": "CCO-Conformant Document Acts Ontology"
      }
    ],
    "http://purl.org/dc/terms/contributor": [
      {
        "@value": "Jonathan M. Vajda"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "en",
        "@value": "The Common Core Ontologies (CCO) Conformant Documents Ontology is a domain ontology that represents the generic domain of entities relevant to the creation, modification, or termination of social arrangements by means of some document. This includes social acts, deontic roles, and directive information and information bearing entities."
      }
    ],
    "http://purl.org/dc/terms/license": [
      {
        "@id": "https://opensource.org/license/BSD-3-Clause"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "CCO-D-Acts is designed to fill a gap in representation of social, legal, normative, and deontic entities for ontologies that rely on the Common Core Ontologies (CCO) suite (https://github.com/CommonCoreOntology/CommonCoreOntologies). Within the Basic Formal Ontology (BFO) ecosystem, the Document Acts (D-Acts) ontology (https://github.com/d-acts/d-acts) is an extension of the OBO Foundry Information Artifact Ontology (IAO). This ontology proposes to transpose that OBO ontology into a CCO equivalent."
      },
      {
        "@language": "en",
        "@value": "The most recent version of this file is always hosted on GitHub https://github.com/jonathanvajda/cco-d-acts"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "CCO-Conformant Document Acts Ontology"
      }
    ],
    "http://www.w3.org/2002/07/owl#imports": [
      {
        "@id": "https://www.commoncoreontologies.org/2024-11-06/CommonCoreOntologiesMerged"
      }
    ],
    "http://www.w3.org/2002/07/owl#versionIRI": [
      {
        "@id": "https://github.com/jonathanvajda/2025-05-24/cco-d-acts"
      }
    ],
    "http://www.w3.org/2002/07/owl#versionInfo": [
      {
        "@language": "en",
        "@value": "2025-05-24"
      }
    ]
  },
  {
    "@id": "https://github.com/jonathanvajda/cco-d-acts/ont00000008",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Comment from source: Claimant roles can either be discharged by one act of fulfilling a duty (e.g. when I pay back $5 owed to a friend) or they can remain intact and require ongoing adhering to a duty. https://plato.stanford.edu/entries/rights/#FormRighHohfAnalSyst discuss the claim of a child to freedom from abuse. That claim remains in existence and the duty to not abuse the child needs to be continuously be acted upon, by a multitude of agents (which all have a duty holder role). This claim is mutually dependent on the duty to abstain from abusing the child."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Claimant Role"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://github.com/jonathanvajda/cco-d-acts/ont00000004"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Deontic Role that inheres in an Agent A, that mutually depends on the existence of a Duty Holder Role borne by Agent B, and that specifies B performaing or abstaining from some Act C, or providing or surrendering some Continuant D to A."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001754": [
      {
        "@language": "en",
        "@value": "Modified, originally from Brochhausen and Otte (D-Acts), http://purl.obolibrary.org/obo/IAO_0021013 which in turn was derived from Hohfeld, WN: Fundamental Legal Conceptions as Applied in Judicial Reasoning. Yale University Press, 1919."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://github.com/jonathanvajda/cco-d-acts"
      }
    ],
    "https://www.commoncoreontologies.org/ont00001762": [
      {
        "@language": "en",
        "@value": "Jonathan M. Vajda"
      }
    ]
  },
  {
    "@id": "https://www.commoncoreontologies.org/ont00000013",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Gain of Generically Dependent Continuant"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "_:n0fa656c7a8f8475da75df9da57ada584b1"
      },
      {
        "@id": "https://www.commoncoreontologies.org/ont00000554"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Gain of Dependent Continuant wherein some Independent Continuant becomes the carrier of some Generically Dependent Continuant."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "A Person forms a Plan, A Person is initiated into a Religion, A photgraphic image is produced."
      }
    ],
