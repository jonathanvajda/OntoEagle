        "@value": "An Information Bearing Artifact that is designed to bear some specific Information Content Entity that is about some temporal region."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001754": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://en.wikipedia.org/w/index.php?title=Timekeeper&oldid=1061681902"
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
