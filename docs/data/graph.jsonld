  {
    "@id": "https://www.commoncoreontologies.org/ont00001999",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Although its basic function remains the same, a Filter can be used in 2 different ways:\n(1) to allow only the desired entities to pass through (e.g. removing dirt from engine oil); or\n(2) to allow everything except the desired entities to pass through (e.g. panning for gold)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Filter Function"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00000323"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "An Artifact Function that is realized in a process where entities of a specific type or which have specified properties enter it or pass through it."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://www.commoncoreontologies.org/ArtifactOntology"
      }
    ]
  },
