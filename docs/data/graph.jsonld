      {
        "@language": "da",
        "@value": "Ny egenskab tilføjet i DCAT 3."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "El primer recurso en una colección ordenada o serie de recursos, al que el recurso pertenece."
      },
      {
        "@language": "en",
        "@value": "The first resource in an ordered collection or series of resources, to which the current resource belongs."
      },
      {
        "@language": "it",
        "@value": "La prima risorsa in una collezione ordinata o in una serie di risorse, di cui la risorsa fa parte."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
