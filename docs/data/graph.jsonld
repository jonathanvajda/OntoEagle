  {
    "@id": "https://www.commoncoreontologies.org/ont00001884",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "condition described by"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00001801"
      }
    ],
    "http://www.w3.org/2002/07/owl#inverseOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00001980"
      }
    ],
    "http://www.w3.org/2002/07/owl#propertyChainAxiom": [
      {
        "@list": [
          {
            "@id": "https://www.commoncoreontologies.org/ont00001917"
          },
          {
            "@id": "http://purl.obolibrary.org/obo/BFO_0000176"
          }
        ]
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "c condition_described_by p iff p is an instance of a Performance Specification, and p has part d, and d is an instance of a Descriptive Information Content Entity, and p prescribes an entity s, and d describes c, and c is an entity that is causally relevant to s existing as prescribed by p."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001760": [
      {
