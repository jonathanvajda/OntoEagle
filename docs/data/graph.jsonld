      {
        "@language": "en",
        "@value": "Act of Expressive Communication"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://www.commoncoreontologies.org/ont00000402"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "An Act of Communication in which an Agent expresses their attitudes or emotions towards some entity."
      }
    ],
    "https://www.commoncoreontologies.org/ont00001754": [
      {
        "@value": "Derived (loosely) from: John Searle's Speech Acts: An Essay in the Philosophy of Language"
