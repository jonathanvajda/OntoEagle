  {
    "@id": "http://www.ontologyrepository.com/CommonCoreOntologies/WebBrowser",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Web Browser"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://www.ontologyrepository.com/CommonCoreOntologies/ContentAccessSoftware"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "A Content Access Software Application that is used to retrieve, present, and traverse information resources on the Internet."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@language": "en",
        "@value": "Google Chrome"
      }
    ],
